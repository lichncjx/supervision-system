# 数据库密码
POSTGRES_PASSWORD=your-strong-password-here

# 本地数据库
DATABASE_URL=postgresql://postgres:password@localhost:5432/supervision

# JWT密钥
JWT_SECRET=your-super-secret-jwt-key-here

# 应用访问地址
# 本地开发用: http://localhost:5000
# 群晖部署用: http://<群晖IP>:18080
NEXT_PUBLIC_APP_URL=http://localhost:5000

# Supabase Preview 数据库（Vercel Preview 用）
# DATABASE_URL 使用 pooler 端口 6543，带 pgbouncer=true
# DIRECT_URL 使用直连端口 5432，用于 prisma migrate
# DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.xxxxx:password@aws-0-xx.pooler.supabase.com:5432/postgres
